{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mybench.is/schemas/v1/harness_currency_snapshot.schema.json",
  "title": "Mybench Harness Currency Snapshot",
  "description": "A caller-supplied, content-addressed version snapshot. The Wave-1 scorer consumes this closed artifact without clock, environment, or network access.",
  "$defs": {
    "hex64": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "minLength": 64,
      "maxLength": 64
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "maxLength": 32
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "snapshot_version", "versions", "digest"],
  "properties": {
    "schema_version": {"const": "1"},
    "kind": {"const": "harness-version-currency-snapshot"},
    "snapshot_version": {"$ref": "#/$defs/semver"},
    "versions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["harness", "latest"],
        "properties": {
          "harness": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._+-]{0,63}$",
            "maxLength": 64
          },
          "latest": {"$ref": "#/$defs/semver"}
        }
      }
    },
    "digest": {"$ref": "#/$defs/hex64"}
  }
}
