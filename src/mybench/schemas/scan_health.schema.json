{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mybench.is/schemas/v1/scan_health.schema.json",
  "title": "Private successful-scan health receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "capture_completed_at",
    "full_scan_completed_at",
    "watches",
    "repos"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "capture_completed_at": {"$ref": "#/$defs/nullable_timestamp"},
    "full_scan_completed_at": {"$ref": "#/$defs/nullable_timestamp"},
    "watches": {"$ref": "#/$defs/locations"},
    "repos": {"$ref": "#/$defs/locations"}
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "minLength": 20,
      "maxLength": 20,
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "nullable_timestamp": {
      "oneOf": [
        {"$ref": "#/$defs/timestamp"},
        {"type": "null"}
      ]
    },
    "locations": {
      "type": "array",
      "maxItems": 4096,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "completed_at"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64,
            "pattern": "^[0-9a-f]{64}$"
          },
          "completed_at": {"$ref": "#/$defs/timestamp"}
        }
      }
    }
  }
}
