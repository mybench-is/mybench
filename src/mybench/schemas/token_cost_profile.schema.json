{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mybench.is/schemas/v1/token_cost_profile.schema.json",
  "title": "Mybench deterministic token and cost scorer section",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "scorer_version",
    "pricing_snapshot",
    "local",
    "publishable",
    "coverage"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "kind": {"const": "token-cost-profile"},
    "scorer_version": {"const": "1.0.0"},
    "pricing_snapshot": {"$ref": "#/$defs/pricingReference"},
    "local": {"$ref": "#/$defs/local"},
    "publishable": {"$ref": "#/$defs/publishable"},
    "coverage": {"$ref": "#/$defs/coverage"}
  },
  "$defs": {
    "hex64": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "basisPointsOrUnknown": {
      "oneOf": [
        {"type": "integer", "minimum": 0, "maximum": 10000},
        {"const": "UNKNOWN"}
      ]
    },
    "publicModel": {
      "enum": [
        "gpt-5",
        "gpt-5-codex",
        "o-series",
        "claude-sonnet",
        "claude-opus",
        "claude-haiku",
        "synthetic",
        "other",
        "UNKNOWN"
      ]
    },
    "pricedModel": {
      "type": "string",
      "pattern": "^(gpt|claude|o[1-9])[a-z0-9._-]*$|^UNKNOWN$",
      "maxLength": 96
    },
    "phase": {
      "enum": ["TASK", "PLAN", "BUILD", "TEST", "DEBUG", "REVIEW", "COMMIT", "UNKNOWN"]
    },
    "tokenBand": {
      "enum": ["0", "1-9k", "10-99k", "100-999k", "1m-9.9m", "10m+"]
    },
    "costBand": {
      "enum": ["$0", "<$1", "$1-9", "$10-99", "$100-999", "$1000+"]
    },
    "shareBand": {
      "enum": ["0-9%", "10-24%", "25-49%", "50-74%", "75-100%", "UNKNOWN"]
    },
    "caveats": {"const": ["provider-reported-inflatable"]},
    "pricingReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "digest", "currency"],
      "properties": {
        "version": {"const": "1.0.0"},
        "digest": {"$ref": "#/$defs/hex64"},
        "currency": {"const": "USD"}
      }
    },
    "pricingFields": {
      "type": "object",
      "required": [
        "estimate_label",
        "pricing_snapshot_version",
        "pricing_snapshot_digest",
        "currency",
        "rounding_rule",
        "trust_tier",
        "caveats"
      ],
      "properties": {
        "estimate_label": {"const": "estimated-public-list-price-equivalent-not-invoice"},
        "pricing_snapshot_version": {"const": "1.0.0"},
        "pricing_snapshot_digest": {"$ref": "#/$defs/hex64"},
        "currency": {"const": "USD"},
        "rounding_rule": {"const": "half-up-after-summing-one-usage-observation"},
        "trust_tier": {"const": "ANCHORED"},
        "caveats": {"$ref": "#/$defs/caveats"}
      }
    },
    "costByModel": {
      "allOf": [
        {"$ref": "#/$defs/pricingFields"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cells",
            "estimate_label",
            "pricing_snapshot_version",
            "pricing_snapshot_digest",
            "currency",
            "rounding_rule",
            "trust_tier",
            "caveats"
          ],
          "properties": {
            "cells": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["model", "cost_micro_usd"],
                "properties": {
                  "model": {"$ref": "#/$defs/pricedModel"},
                  "cost_micro_usd": {
                    "oneOf": [
                      {"type": "integer", "minimum": 0},
                      {"const": "UNKNOWN"}
                    ]
                  }
                }
              }
            },
            "estimate_label": {},
            "pricing_snapshot_version": {},
            "pricing_snapshot_digest": {},
            "currency": {},
            "rounding_rule": {},
            "trust_tier": {},
            "caveats": {}
          }
        }
      ]
    },
    "costPerEpisode": {
      "allOf": [
        {"$ref": "#/$defs/pricingFields"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cells",
            "unknown_episode_count",
            "estimate_label",
            "pricing_snapshot_version",
            "pricing_snapshot_digest",
            "currency",
            "rounding_rule",
            "trust_tier",
            "caveats"
          ],
          "properties": {
            "cells": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["cost_band", "episode_count"],
                "properties": {
                  "cost_band": {"$ref": "#/$defs/costBand"},
                  "episode_count": {"type": "integer", "minimum": 1}
                }
              }
            },
            "unknown_episode_count": {"type": "integer", "minimum": 0},
            "estimate_label": {},
            "pricing_snapshot_version": {},
            "pricing_snapshot_digest": {},
            "currency": {},
            "rounding_rule": {},
            "trust_tier": {},
            "caveats": {}
          }
        }
      ]
    },
    "local": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens_by_model",
        "tokens_by_phase",
        "planning_tokens",
        "implementation_tokens",
        "rework_token_share_basis_points",
        "abandoned_session_token_share_basis_points",
        "pricing_unknown_observations",
        "cost_claims",
        "caveats"
      ],
      "properties": {
        "tokens_by_model": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["model", "tokens"],
            "properties": {
              "model": {"$ref": "#/$defs/publicModel"},
              "tokens": {"type": "integer", "minimum": 0}
            }
          }
        },
        "tokens_by_phase": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["phase", "tokens"],
            "properties": {
              "phase": {"$ref": "#/$defs/phase"},
              "tokens": {"type": "integer", "minimum": 0}
            }
          }
        },
        "planning_tokens": {"type": "integer", "minimum": 0},
        "implementation_tokens": {"type": "integer", "minimum": 0},
        "rework_token_share_basis_points": {"$ref": "#/$defs/basisPointsOrUnknown"},
        "abandoned_session_token_share_basis_points": {"$ref": "#/$defs/basisPointsOrUnknown"},
        "pricing_unknown_observations": {"type": "integer", "minimum": 0},
        "cost_claims": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fingerprint.token_cost.cost_by_model.exact": {"$ref": "#/$defs/costByModel"},
            "fingerprint.token_cost.cost_per_episode.exact": {"$ref": "#/$defs/costPerEpisode"}
          }
        },
        "caveats": {"$ref": "#/$defs/caveats"}
      }
    },
    "tokensByModelPublic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cells",
        "model_vocabulary_version",
        "token_accounting_policy_version",
        "trust_tier",
        "caveats"
      ],
      "properties": {
        "cells": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["model", "token_band"],
            "properties": {
              "model": {"$ref": "#/$defs/publicModel"},
              "token_band": {"$ref": "#/$defs/tokenBand"}
            }
          }
        },
        "model_vocabulary_version": {"const": "1.0.0"},
        "token_accounting_policy_version": {"const": "1.0.0"},
        "trust_tier": {"const": "ANCHORED"},
        "caveats": {"$ref": "#/$defs/caveats"}
      }
    },
    "tokensByPhasePublic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cells",
        "classifier_version",
        "token_accounting_policy_version",
        "trust_tier",
        "caveats"
      ],
      "properties": {
        "cells": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["phase", "token_band"],
            "properties": {
              "phase": {"$ref": "#/$defs/phase"},
              "token_band": {"$ref": "#/$defs/tokenBand"}
            }
          }
        },
        "classifier_version": {"const": "1.0.0"},
        "token_accounting_policy_version": {"const": "1.0.0"},
        "trust_tier": {"const": "ANCHORED"},
        "caveats": {"$ref": "#/$defs/caveats"}
      }
    },
    "ratioPublic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ratio_band", "classifier_version", "trust_tier", "caveats"],
      "properties": {
        "ratio_band": {"enum": ["UNKNOWN", "<0.5", "0.5-0.99", "1.0-1.99", "2.0+"]},
        "classifier_version": {"const": "1.0.0"},
        "trust_tier": {"const": "ANCHORED"},
        "caveats": {"$ref": "#/$defs/caveats"}
      }
    },
    "sharePublic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["share_band", "definition_version", "trust_tier", "caveats"],
      "properties": {
        "share_band": {"$ref": "#/$defs/shareBand"},
        "definition_version": {"const": "1.0.0"},
        "trust_tier": {"const": "ANCHORED"},
        "caveats": {"$ref": "#/$defs/caveats"}
      }
    },
    "publishable": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fingerprint.token_cost.tokens_by_model.band": {"$ref": "#/$defs/tokensByModelPublic"},
        "fingerprint.token_cost.tokens_by_phase.band": {"$ref": "#/$defs/tokensByPhasePublic"},
        "fingerprint.token_cost.planning_to_implementation_ratio.band": {"$ref": "#/$defs/ratioPublic"},
        "fingerprint.token_cost.rework_token_share": {"$ref": "#/$defs/sharePublic"},
        "fingerprint.token_cost.abandoned_session_token_share": {"$ref": "#/$defs/sharePublic"}
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "producer", "observations", "missing_ambiguous"],
      "properties": {
        "schema_version": {"const": "1"},
        "producer": {"const": "token-cost-profile"},
        "observations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["input_class", "basis", "coverage_basis_points", "confidence", "evidence_state"],
            "properties": {
              "input_class": {"const": "token-data"},
              "basis": {"const": "structurally-valid-token-metadata-per-eligible-session"},
              "coverage_basis_points": {"$ref": "#/$defs/basisPointsOrUnknown"},
              "confidence": {"enum": ["LOW", "MEDIUM", "HIGH", "UNKNOWN"]},
              "evidence_state": {"enum": ["available", "partial", "unknown"]}
            }
          }
        },
        "missing_ambiguous": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["category", "count"],
            "properties": {
              "category": {"enum": ["missing-token-data", "unknown-phase", "missing-model"]},
              "count": {"type": "integer", "minimum": 1}
            }
          }
        }
      }
    }
  }
}
