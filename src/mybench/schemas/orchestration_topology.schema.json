{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mybench.is/schemas/v1/orchestration-topology.schema.json",
  "title": "Mybench publishable orchestration-topology aggregate",
  "description": "Closed aggregate-only topology shape. Free-form names, paths, contents, exact counts, and exact depths are structurally impossible.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "trust_tier",
    "state_basis",
    "observed_on",
    "evidence_sources",
    "structure_count_bands",
    "presence_flags"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "kind": {"const": "orchestration-topology-aggregate"},
    "trust_tier": {"const": "ANCHORED"},
    "state_basis": {"const": "scan-time-state-not-evidence-period"},
    "observed_on": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "evidence_sources": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "coverage_basis_points"],
          "properties": {
            "source": {"const": "file-structure"},
            "coverage_basis_points": {"const": 10000}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "coverage_basis_points"],
          "properties": {
            "source": {"const": "transcript-delegation"},
            "coverage_basis_points": {
              "oneOf": [
                {"type": "integer", "minimum": 0, "maximum": 10000},
                {"const": "UNKNOWN"}
              ]
            }
          }
        }
      ],
      "items": false
    },
    "structure_count_bands": {"$ref": "#/$defs/bandedCategories"},
    "instruction_depth_band": {"$ref": "#/$defs/countBand"},
    "presence_flags": {"$ref": "#/$defs/presenceCategories"}
  },
  "$defs": {
    "countBand": {
      "enum": ["0", "1-4", "5-19", "20-99", "100-999", "1000+"]
    },
    "bandedCategories": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "custom_agents": {"$ref": "#/$defs/countBand"},
        "hooks": {"$ref": "#/$defs/countBand"},
        "instruction_files": {"$ref": "#/$defs/countBand"},
        "lanes": {"$ref": "#/$defs/countBand"},
        "plan_task_directories": {"$ref": "#/$defs/countBand"},
        "skills": {"$ref": "#/$defs/countBand"},
        "validation_scripts": {"$ref": "#/$defs/countBand"},
        "worktrees": {"$ref": "#/$defs/countBand"}
      }
    },
    "presenceCategories": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "custom_agents": {"const": true},
        "hooks": {"const": true},
        "instruction_files": {"const": true},
        "lanes": {"const": true},
        "plan_task_directories": {"const": true},
        "skills": {"const": true},
        "validation_scripts": {"const": true},
        "worktrees": {"const": true}
      }
    }
  }
}
