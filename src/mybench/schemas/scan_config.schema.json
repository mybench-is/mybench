{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mybench.dev/schemas/v1/scan_config.schema.json",
  "title": "Private local scan configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "watches", "repos", "exclusions"],
  "properties": {
    "schema_version": {"const": "1"},
    "watches": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "source"],
        "properties": {
          "path": {"$ref": "#/$defs/path"},
          "source": {"enum": ["claude-code", "codex"]}
        }
      }
    },
    "repos": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/path"}
    },
    "exclusions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4096,
        "pattern": "^[^\\u0000-\\u001f]+$"
      }
    }
  },
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^/[^\\u0000-\\u001f]*$"
    }
  }
}
