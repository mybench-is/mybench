{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mybench.is/schemas/v1/reference_target_join.schema.json",
  "title": "Mybench Normalized Reference-to-Repository-Target Join Corpus",
  "description": "Closed local-only A8 schema joining a committed subject-agent reference invocation to an admitted Git blob commitment. Filenames, paths, transcript bytes, repository bytes, and publication fields have no field.",
  "$defs": {
    "hex40": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$",
      "minLength": 40,
      "maxLength": 40
    },
    "hex64": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "minLength": 64,
      "maxLength": 64
    },
    "referencePointer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "block_index", "record_commitment"],
      "properties": {
        "field": {"const": "tool-input"},
        "block_index": {"type": "integer", "minimum": 0},
        "record_commitment": {"$ref": "#/$defs/hex64"}
      }
    },
    "targetCommitment": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "digest"],
          "properties": {
            "algorithm": {"const": "git-sha1"},
            "digest": {"$ref": "#/$defs/hex40"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "digest"],
          "properties": {
            "algorithm": {"const": "git-sha256"},
            "digest": {"$ref": "#/$defs/hex64"}
          }
        }
      ]
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "source", "session_id", "record_index", "subevent_index", "reference_pointer", "target_commitment"],
      "properties": {
        "schema_version": {"const": "1"},
        "kind": {"const": "normalized-reference-target-event"},
        "source": {"const": "cross-stream"},
        "session_id": {"$ref": "#/$defs/hex64"},
        "record_index": {"type": "integer", "minimum": 0},
        "subevent_index": {"const": 0},
        "reference_pointer": {"$ref": "#/$defs/referencePointer"},
        "target_commitment": {"$ref": "#/$defs/targetCommitment"}
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "corpus_commitment", "manifest", "events"],
  "properties": {
    "schema_version": {"const": "1"},
    "kind": {"const": "normalized-reference-target-corpus-artifact"},
    "corpus_commitment": {"$ref": "#/$defs/hex64"},
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "normalizer", "inputs", "event_count"],
      "properties": {
        "schema_version": {"const": "1"},
        "kind": {"const": "normalized-reference-target-manifest"},
        "normalizer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {"const": "mybench.normalizer.reference_join"},
            "version": {"const": "1.0.0"}
          }
        },
        "inputs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["transcript_corpus_commitment", "repo_corpus_commitment"],
          "properties": {
            "transcript_corpus_commitment": {"$ref": "#/$defs/hex64"},
            "repo_corpus_commitment": {"$ref": "#/$defs/hex64"}
          }
        },
        "event_count": {"type": "integer", "minimum": 1}
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/event"}
    }
  }
}
